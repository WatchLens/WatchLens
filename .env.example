# --- Database ---
POSTGRES_USER=vidreclab
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=vidreclab

# --- Backend ---
DATABASE_URL=postgresql://vidreclab:changeme_postgres_password@db:5432/vidreclab
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_EXPIRE_DAYS=7

# --- Admin bootstrap ---
ADMIN_LOGIN_ID=admin
ADMIN_PASSWORD=changeme_admin_password

# --- Frontend ---
VITE_API_URL=/api

# --- Data serving ---
DATA_BASE_URL=/data

# --- Host port mapping ---
# HOST_PORT  the port on the host machine that maps to the frontend container.
# HOST_BIND  the host interface to bind to. 127.0.0.1 = local only;
#            set to 0.0.0.0 to expose to the LAN, or pair with a reverse proxy.
HOST_PORT=8080
HOST_BIND=127.0.0.1

# --- Auth cookie ---
# Set true in production (HTTPS); false for plain-HTTP local dev.
COOKIE_SECURE=false

# --- CORS allow-list (production) ---
# JSON-encoded list of origins permitted to call the API. Defaults in
# backend/app/config.py cover localhost; override here when deploying
# behind a real domain (HTTPS).
# CORS_ORIGINS=["https://study.example.org"]
